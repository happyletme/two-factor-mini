page {
  background-color: #f7f8fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* --- 头部样式 (保持不变) --- */
.header {
  padding: 40rpx 40rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  background: #f7f8fa;
  z-index: 10;
  /* 固定头部高度，防止布局跳动 */
  height: 120rpx;
  box-sizing: border-box;
}
/* ... header 内部样式保持不变 ... */
.header-left { display: flex; flex-direction: column; }
.title { font-size: 48rpx; font-weight: 800; color: #1a1a1a; line-height: 1.2; }
.subtitle { font-size: 24rpx; color: #999; margin-top: 8rpx; letter-spacing: 2rpx; text-transform: uppercase; }
.timer-badge { background: rgba(7, 193, 96, 0.1); color: #07c160; padding: 10rpx 24rpx; border-radius: 30rpx; font-size: 26rpx; font-weight: 600; display: flex; align-items: center; }
.timer-icon { margin-right: 8rpx; font-size: 24rpx; }

/* --- 列表区域 --- */
.list {
  flex: 1;
  padding: 20rpx 40rpx;
  box-sizing: border-box;
  position: relative; /* 为定位做准备 */
}

.list-spacer {
  height: 200rpx;
}

/* --- 卡片样式 --- */
.card {
  background: #ffffff;
  /* 关键修改：固定高度以便计算 */
  height: 190rpx;
  padding: 0 40rpx; /* 上下padding改为用 flex 布局控制，或者包含在 height 内 */
  display: flex;
  flex-direction: column;
  justify-content: center;

  border-radius: 24rpx;
  margin-bottom: 30rpx; /* 190 + 30 = 220rpx 总高度 */
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.03);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

/* 拖拽时，原位置的卡片变为透明 */
.card-hidden {
  opacity: 0;
}

/* 影子卡片 (拖拽时显示) */
.ghost-card {
  position: fixed; /* 使用 fixed 覆盖在所有内容之上 */
  left: 40rpx;
  right: 40rpx;
  z-index: 999;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.15); /* 更深的阴影 */
  transform: scale(1.02); /* 稍微放大 */
  background: rgba(255, 255, 255, 0.95);
  pointer-events: none; /* 让事件穿透，不影响底层 touchmove */
}

.card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: #07c160;
}

.card-header {
  margin-bottom: 20rpx;
}

.issuer {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.account-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.code-container {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.code {
  font-size: 64rpx;
  color: #07c160;
  font-weight: bold;
  letter-spacing: 6rpx;
  font-family: 'Courier New', Courier, monospace;
}

.copy-hint {
  font-size: 22rpx;
  color: #ccc;
}

/* --- 更多操作按钮 --- */
.more-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.more-icon {
  color: #ccc;
  font-weight: bold;
  font-size: 32rpx;
  letter-spacing: 2rpx;
}

/* --- 空状态和底部按钮 (保持不变) --- */
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 150rpx; }
.empty-icon { width: 160rpx; height: 160rpx; background: #e8f5e9; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 40rpx; }
.icon-shield { width: 60rpx; height: 70rpx; background: #07c160; border-radius: 0 0 30rpx 30rpx; position: relative; }
.icon-shield::before { content: ''; position: absolute; top: -15rpx; left: 0; width: 60rpx; height: 30rpx; background: #07c160; border-radius: 10rpx 10rpx 0 0; }
.empty-title { font-size: 34rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; }
.empty-desc { font-size: 26rpx; color: #999; }
/* --- 底部按钮区域优化 --- */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  /* 增加底部内边距，适配全面屏小黑条 */
  padding: 0 40rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  /* 背景渐变高度适当增加，过渡更自然 */
  background: linear-gradient(to top, rgba(247,248,250, 1) 20%, rgba(247,248,250, 0.8) 60%, rgba(247,248,250, 0));
  pointer-events: none; /* 让渐变层不阻挡下方列表滚动 */
  z-index: 100;
}

.btn-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 40rpx; /* 按钮距离底部的距离 */
  pointer-events: auto; /* 恢复按钮的可点击性 */
}

/* 按钮通用基础样式 */
.action-btn {
  height: 110rpx;
  line-height: 110rpx;
  border-radius: 55rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.15s ease;
  margin: 0 !important; /* 清除默认margin */
  padding: 0;
}

.action-btn::after {
  border: none; /* 清除小程序按钮默认边框 */
}

.action-btn:active {
  transform: scale(0.96); /* 点击缩放反馈 */
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
  margin-top: -4rpx;
}

/* 次要按钮样式 (云操作) */
.secondary-btn {
  width: 32% !important; /* 占比约 1/3 */
  background: #ffffff;
  color: #333;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.08);
}

/* 主要按钮样式 (添加账号) */
.primary-btn {
  width: 64% !important; /* 占比约 2/3 */
  background: linear-gradient(135deg, #07c160, #05a350);
  color: white;
  box-shadow: 0 15rpx 30rpx rgba(7, 193, 96, 0.35);
}

/* 如果想要两个按钮等宽，可以将上面两个 width 都改为 48% !important */

