/* pages/assets/assets.wxss */
page {
  background-color: #f5f6f8;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* --- 头部区域 --- */
.header-section {
  background: #fff;
  padding: 30rpx 40rpx 0;
  border-bottom-left-radius: 30rpx;
  border-bottom-right-radius: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
  z-index: 10;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.main-title { font-size: 44rpx; font-weight: 800; color: #1a1a1a; display: block; }
.sub-title { font-size: 24rpx; color: #999; margin-top: 6rpx; display: block; }

/* --- 倒计时徽章 (金色版) --- */
.timer-badge {
  background: rgba(197, 160, 40, 0.1);
  color: #c5a028;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  transition: all 0.3s;
}

.loading-badge {
  opacity: 0.7;
}

.timer-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

/* --- Tab 切换器 --- */
.tab-container {
  display: flex;
  justify-content: flex-start;
  padding-bottom: 0;
}

.tab-item {
  padding: 20rpx 10rpx;
  margin-right: 50rpx;
  font-size: 30rpx;
  color: #999;
  font-weight: 600;
  position: relative;
  transition: all 0.3s;
}

.active-tab {
  color: #1a1a1a;
  font-size: 32rpx;
  font-weight: 800;
}

.active-tab::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #1a1a1a;
  border-radius: 4rpx;
}

/* --- 列表区域 --- */
.list-container {
  flex: 1;
  padding: 30rpx 30rpx;
  box-sizing: border-box;
}
.list-spacer { height: 150rpx; }
.empty-tip { text-align: center; color: #ccc; margin-top: 100rpx; font-size: 28rpx; }

/* --- 通用卡片基础 --- */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}

/* pages/assets/assets.wxss */
/* ... (保留之前的样式) ... */

/* === 新增：汇率输入框样式 === */
/* === 修改：汇率输入框样式增强 === */
.converter-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
  display: flex;
  flex-direction: column;
  border-left: 8rpx solid #2b6cb0;
}

/* 标题栏：左右布局 */
.converter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.converter-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* 提示标签：蓝色小气泡 */
.edit-tag {
  font-size: 22rpx;
  color: #2b6cb0;
  background: #ebf8ff;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  font-weight: 600;
}

/* 输入框容器：灰色背景，模拟输入框外观 */
.input-wrapper {
  display: flex;
  align-items: center;
  background: #f7f9fc; /* 浅灰背景 */
  border: 2rpx solid #e2e8f0; /* 边框 */
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  transition: all 0.3s;
}

/* 聚焦态（可选，如果想做点击变色效果） */
.input-wrapper:active {
  border-color: #2b6cb0;
  background: #fff;
}

.currency-prefix {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
  font-family: 'DIN Alternate', sans-serif;
}

.converter-input {
  flex: 1;
  height: 60rpx;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  font-family: 'DIN Alternate', monospace;
  /* 去掉之前的下划线样式 */
  border-bottom: none;
}

.input-placeholder {
  color: #cbd5e0;
  font-size: 32rpx;
  font-weight: normal;
}


.converter-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.converter-input {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  height: 60rpx;
  border-bottom: 1rpx solid #eee;
  font-family: 'DIN Alternate', monospace;
}

/* === 新增：汇率卡片样式 === */
.currency-card {
  border-left: 8rpx solid #4299e1; /* 浅蓝色 */
}

/* 确保之前的样式兼容 */
.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* ... (保留之前的 footer 等样式) ... */


/* === 样式: 国内金价卡片 (Domestic & Shanghai) === */
.domestic-card { border-left: 8rpx solid #d69e2e; }

.shop-info { display: flex; flex-direction: column; }
.shop-brand { font-size: 34rpx; font-weight: 800; color: #333; }
.shop-tag {
  font-size: 20rpx; color: #d69e2e; background: #fff8e6;
  padding: 2rpx 10rpx; border-radius: 6rpx; margin-top: 8rpx; align-self: flex-start;
}

.coin-info { display: flex; flex-direction: column; }
.coin-symbol { font-size: 32rpx; font-weight: 800; color: #333; }
.coin-name { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.gold-price-box { display: flex; align-items: baseline; }
.currency-symbol { font-size: 24rpx; color: #d69e2e; font-weight: bold; margin-right: 4rpx; }
.gold-price { font-size: 44rpx; color: #d69e2e; font-weight: bold; font-family: 'DIN Alternate', monospace; }
.gold-unit { font-size: 22rpx; color: #999; margin-left: 4rpx; }

.card-footer-line {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}
.update-time { font-size: 22rpx; color: #ccc; }

/* --- 底部按钮 --- */
.footer {
  position: fixed;
  bottom: 0; left: 0; width: 100%;
  padding: 20rpx 40rpx 60rpx;
  background: linear-gradient(to top, #f5f6f8 80%, rgba(245,246,248,0));
  box-sizing: border-box;
  pointer-events: none;
}

.refresh-btn {
  pointer-events: auto;
  width: 100% !important;
  height: 110rpx;
  line-height: 110rpx;
  background: #c5a028;
  color: white;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 55rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(197, 160, 40, 0.4);
  border: none;
  transition: transform 0.1s, opacity 0.1s;
}

.refresh-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.refresh-btn[disabled] {
  background: #e0e0e0;
  box-shadow: none;
  color: #999;
  opacity: 1;
}

.refresh-icon { margin-right: 10rpx; }
