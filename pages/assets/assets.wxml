<!-- pages/assets/assets.wxml -->

<!-- 引入 WXS 脚本用于实时计算 -->
<wxs module="tools">
  var calculate = function(rate, amount) {
    if (!amount) return '0.00';
    var res = rate * amount;
    // 针对日元、韩元、越南盾等大额货币，保留不同的小数位
    if (res > 1000) return res.toFixed(0);
    return res.toFixed(2);
  }
  module.exports = {
    calculate: calculate
  };
</wxs>

<view class="container">

  <!-- 顶部 Header + Tab 切换 -->
  <view class="header-section">
    <view class="header-top">
      <view>
        <text class="main-title">资产行情</text>
        <text class="sub-title">实时市场价格监控</text>
      </view>
      <view class="timer-badge {{loading ? 'loading-badge' : ''}}" bindtap="manualRefresh">
        <text class="timer-icon">{{loading ? '...' : '↻'}}</text>
        <text>刷新: {{loading ? '更新中' : remaining + 's'}}</text>
      </view>
    </view>

    <!-- Tab 切换器 -->
    <view class="tab-container">
      <view class="tab-item {{currentTab === 'global' ? 'active-tab' : ''}}" bindtap="switchTab" data-tab="global">
        国际市场
      </view>
      <view class="tab-item {{currentTab === 'domestic' ? 'active-tab' : ''}}" bindtap="switchTab" data-tab="domestic">
        门店金价
      </view>
      <!-- 新增 Tab -->
      <view class="tab-item {{currentTab === 'currency' ? 'active-tab' : ''}}" bindtap="switchTab" data-tab="currency">
        货币汇率
      </view>
    </view>
  </view>

  <!-- 列表区域 -->
  <scroll-view scroll-y class="list-container">

    <!-- 场景 1: 国际市场 -->
    <block wx:if="{{currentTab === 'global'}}">
      <view class="card domestic-card" wx:for="{{globalList}}" wx:key="symbol">
        <view class="card-row">
          <view class="coin-info">
            <text class="coin-symbol">{{item.symbol}}</text>
            <text class="coin-name">{{item.name}}</text>
          </view>
          <view class="gold-price-box">
            <text class="currency-symbol">$</text>
            <text class="gold-price">{{item.price}}</text>
            <text class="gold-unit" wx:if="{{item.unit}}">/{{item.unit}}</text>
          </view>
        </view>
        <view class="card-footer-line">
          <text class="update-time">报价时间: {{item.time}}</text>
        </view>
      </view>
      <view wx:if="{{globalList.length === 0 && !loading}}" class="empty-tip">暂无国际行情数据</view>
    </block>

    <!-- 场景 2: 国内金店 -->
    <block wx:if="{{currentTab === 'domestic'}}">
      <view class="card domestic-card" wx:for="{{domesticList}}" wx:key="brand">
        <view class="card-row">
          <view class="shop-info">
            <text class="shop-brand">{{item.brand}}</text>
            <text class="shop-tag">{{item.type}}</text>
          </view>
          <view class="gold-price-box">
            <text class="currency-symbol">¥</text>
            <text class="gold-price">{{item.price}}</text>
            <text class="gold-unit">/{{item.unit}}</text>
          </view>
        </view>
        <view class="card-footer-line">
          <text class="update-time">报价时间: {{item.time || lastUpdatedTime}}</text>
        </view>
      </view>
      <view wx:if="{{domesticList.length === 0 && !loading}}" class="empty-tip">暂无金店报价数据</view>
    </block>

    <!-- 场景 3: 上海黄金 (保留代码，如果需要显示) -->
    <block wx:if="{{currentTab === 'shanghai'}}">
      <view class="card domestic-card" wx:for="{{shanghaiList}}" wx:key="symbol">
        <view class="card-row">
          <view class="coin-info">
            <text class="coin-symbol">{{item.symbol}}</text>
            <text class="coin-name">{{item.name}}</text>
          </view>
          <view class="gold-price-box">
            <text class="currency-symbol">¥</text>
            <text class="gold-price">{{item.price}}</text>
            <text class="gold-unit">/元/克</text>
          </view>
        </view>
        <view class="card-footer-line">
          <text class="update-time">报价时间: {{item.time}}</text>
        </view>
      </view>
    </block>

    <!-- 场景 4: 货币汇率 -->
    <block wx:if="{{currentTab === 'currency'}}">

      <!-- === 修改开始：增强输入框视觉 === -->
      <view class="converter-box">
        <view class="converter-header">
          <text class="converter-title">持有人民币 (CNY)</text>
          <view class="edit-tag">
            <text>✎ 点此修改金额</text>
          </view>
        </view>

        <view class="input-wrapper">
          <text class="currency-prefix">¥</text>
          <input
            class="converter-input"
            type="digit"
            value="{{baseAmount}}"
            bindinput="onAmountInput"
            placeholder="请输入金额"
            placeholder-class="input-placeholder"
          />
        </view>
      </view>
      <!-- === 修改结束 === -->

      <view class="card currency-card" wx:for="{{currencyList}}" wx:key="code">
        <view class="card-row">
          <view class="coin-info">
            <text class="coin-symbol">{{item.code}}</text>
            <text class="coin-name">{{item.name}}</text>
          </view>
          <view class="gold-price-box">
            <!-- 使用 WXS 实时计算: rate * baseAmount -->
            <text class="gold-price">{{tools.calculate(item.rate, baseAmount)}}</text>
            <text class="gold-unit" style="margin-left:8rpx;">{{item.code}}</text>
          </view>
        </view>
        <view class="card-footer-line" style="display:flex; justify-content:space-between;">
          <text class="update-time">报价时间: {{item.time}}</text>
          <text class="update-time">汇率: 1 CNY ≈ {{item.rate}} {{item.code}}</text>
        </view>
      </view>
      <view wx:if="{{currencyList.length === 0 && !loading}}" class="empty-tip">暂无汇率数据</view>
    </block>

    <view class="list-spacer"></view>
  </scroll-view>

  <!-- 底部按钮 -->
  <!--<view class="footer">
    <button class="refresh-btn" bindtap="manualRefresh" disabled="{{loading}}">
      <text class="refresh-icon">↻</text> 立即刷新
    </button>
  </view>-->

</view>
