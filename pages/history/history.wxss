page {
  background: #f3f5f9;
}

.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.header {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.toolbar {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.chips,
.tabs {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.chip,
.tab {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #6b7280;
  background: #f3f4f6;
  border: 1rpx solid #e5e7eb;
}

.chip.active,
.tab.active {
  color: #fff;
  background: #c69223;
  border-color: #c69223;
}

.chart-wrap {
  position: relative;
  width: 100%;
  height: 560rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #fff;
}

ec-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.9);
}

.mask.error {
  color: #dc2626;
}
