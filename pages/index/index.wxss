/* ===== 商务黑金主题 ===== */
page {
  background: linear-gradient(180deg, #eef1f5 0%, #f7f8fa 100%);
  min-height: 100vh;
}

.container {
  padding: 24rpx;
}

/* 1) 顶部行情 Banner */
.banner-card {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 34rpx 30rpx 28rpx;
  margin-bottom: 30rpx;
  color: #fff;
  background:
    linear-gradient(140deg, #14171c 0%, #1e232b 46%, #0f1115 100%);
  box-shadow:
    0 14rpx 36rpx rgba(7, 9, 12, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

/* 金色光斑 */
.banner-card::before {
  content: '';
  position: absolute;
  right: -80rpx;
  top: -120rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212, 175, 55, 0.24), rgba(212, 175, 55, 0) 66%);
}

/* 细金线 */
.banner-card::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(212,175,55,0), rgba(212,175,55,0.75), rgba(212,175,55,0));
}

.banner-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.banner-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #e8edf5;
  letter-spacing: 0.5rpx;
}

.banner-time {
  font-size: 20rpx;
}

.banner-main {
  display: flex;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.price-big {
  font-size: 82rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: 1rpx;
  margin-right: 16rpx;
  color: #d4af37;
  text-shadow: 0 2rpx 8rpx rgba(212, 175, 55, 0.2);
}

.price-change {
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.price-change.up {
  color: #ff8a80;
  background: rgba(231, 76, 60, 0.16);
  border: 1rpx solid rgba(231, 76, 60, 0.28);
}

.price-change.down {
  color: #7ee2ad;
  background: rgba(46, 204, 113, 0.14);
  border: 1rpx solid rgba(46, 204, 113, 0.3);
}

.arrow {
  margin-left: 6rpx;
}

.banner-footer {
  text-align: right;
  font-size: 22rpx;
  color: rgba(212, 175, 55, 0.95);
}

/* 2) 区块标题 */
.section-title {
  margin: 8rpx 0 20rpx;
  padding-left: 4rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #1b1f27;
  letter-spacing: 0.6rpx;
}

/* 3) 工具区 */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 30rpx;
  padding: 20rpx 8rpx 4rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.tool-item {
  width: 25%;
  margin-bottom: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.tool-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  font-size: 42rpx;
  background: linear-gradient(180deg, #fff8e6 0%, #f5e4b6 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
}

.tool-name {
  font-size: 24rpx;
  color: #4b5563;
}

.tool-tag {
  position: absolute;
  top: -6rpx;
  right: 8rpx;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  line-height: 1;
  color: #fff;
  background: linear-gradient(90deg, #f97316, #ef4444);
}

/* 4) 今日品牌金价列表（重点） */
.brand-list {
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid #eceff3;
  padding: 0 24rpx;
}

.list-header,
.list-item {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  border-bottom: 1rpx solid #edf0f3;
}

.list-header {
  min-height: 84rpx;
  color: #9aa3af;
  font-size: 26rpx;
  font-weight: 500;
}

.list-item {
  font-size: 38rpx;
}

.list-item:last-child {
  border-bottom: none;
}

/* 列宽 */
.list-header text:nth-child(1),
.brand-name {
  width: 38%;
  text-align: left;
}

.list-header text:nth-child(2),
.list-header text:nth-child(3),
.brand-price {
  width: 31%;
  text-align: center;
}

/* 文案色 */
.brand-name {
  color: #111827;
  font-weight: 700;
}

.brand-price {
  color: #d74f4f;
  font-weight: 700;
  letter-spacing: 0.2rpx;
}

/* 保留旧类 */
.brand-fee {
  width: 31%;
  text-align: center;
  color: #9aa3af;
  font-size: 30rpx;
}
