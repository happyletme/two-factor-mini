/* 页面背景 */
page {
  background: linear-gradient(180deg, #eef1f5 0%, #f6f7f9 100%);
  color: #333;
}

.container {
  padding: 30rpx;
}

/* 1. 结果卡片 - 黑金风格 */
.result-card {
  background: linear-gradient(140deg, #14171c 0%, #1e232b 46%, #0f1115 100%);
  border-radius: 28rpx;
  padding: 40rpx 30rpx;
  color: #fff;
  box-shadow: 0 14rpx 36rpx rgba(7, 9, 12, 0.2);
  margin-bottom: 40rpx;
  position: relative;
  overflow: hidden;
}

/* 金色装饰光斑 */
.result-card::before {
  content: '';
  position: absolute;
  right: -60rpx;
  top: -60rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212, 175, 55, 0.2), rgba(212, 175, 55, 0) 70%);
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.result-row.small {
  margin-top: 20rpx;
  opacity: 0.9;
}

.label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.value {
  font-weight: 700;
  color: #d4af37; /* 金色 */
}

.value.big {
  font-size: 64rpx;
  text-shadow: 0 2rpx 8rpx rgba(212, 175, 55, 0.2);
}

.divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 30rpx 0;
}

/* 2. 输入表单卡片 */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 0 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 40rpx;
}

.input-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 110rpx;
  border-bottom: 1rpx solid #f0f2f5;
}

.input-group.no-border {
  border-bottom: none;
}

.input-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #1b1f27;
  width: 240rpx;
}

.input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

input {
  text-align: right;
  font-size: 32rpx;
  font-weight: 600;
  color: #1b1f27;
  height: 100%;
  margin-right: 16rpx;
}

.ph-color {
  color: #c0c4cc;
  font-weight: 400;
}

.unit {
  font-size: 26rpx;
  color: #9aa3af;
}

/* 3. 按钮 */
.reset-btn {
  background: #fff;
  color: #6b7280;
  border: 1rpx solid #d1d5db;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.reset-btn::after {
  border: none;
}

/* 4. 提示 */
.tips {
  margin-top: 40rpx;
  padding: 0 10rpx;
  font-size: 22rpx;
  color: #9aa3af;
  text-align: center;
  line-height: 1.5;
}
