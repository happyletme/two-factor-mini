<view class="container">

  <!-- 1. 结果展示卡片 (黑金风格) -->
  <view class="result-card">
    <view class="result-row">
      <text class="label">预估总价 (元)</text>
      <text class="value big">¥ {{total}}</text>
    </view>
    <view class="divider"></view>
    <view class="result-row small">
      <text class="label">平均克价 (含工费)</text>
      <text class="value">¥ {{average}} /克</text>
    </view>
  </view>

  <!-- 2. 输入表单 -->
  <view class="form-card">

    <view class="input-group">
      <view class="input-label">今日金价</view>
      <view class="input-wrapper">
        <input type="digit" value="{{price}}" bindinput="onPriceInput" placeholder="请输入单价" placeholder-class="ph-color"/>
        <text class="unit">元/克</text>
      </view>
    </view>

    <view class="input-group">
      <view class="input-label">黄金克重</view>
      <view class="input-wrapper">
        <input type="digit" value="{{weight}}" bindinput="onWeightInput" placeholder="请输入克重" placeholder-class="ph-color"/>
        <text class="unit">克</text>
      </view>
    </view>

    <view class="input-group no-border">
      <view class="input-label">总工费/附加费</view>
      <view class="input-wrapper">
        <input type="digit" value="{{fee}}" bindinput="onFeeInput" placeholder="0" placeholder-class="ph-color"/>
        <text class="unit">元</text>
      </view>
    </view>

  </view>

  <!-- 3. 操作按钮 -->
  <view class="btn-area">
    <button class="reset-btn" bindtap="reset">重置清空</button>
  </view>

  <!-- 4. 提示文案 -->
  <view class="tips">
    <text>说明：计算结果仅供参考，实际价格请以金店最终报价为准。</text>
  </view>

</view>
